# Kopiere diese Datei zu .env und trage deine Werte ein.
# .env ist in .gitignore und wird NIEMALS committet!

DB_HOST=localhost
DB_PORT=5432
DB_NAME=pulsestack
DB_USER=pulsestack
DB_PASSWORD=pulsestack_dev

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_SERVERS=localhost:9092

# Phase 5: JWT Secret (mind. 32 Zeichen, in Prod unbedingt ändern!)
JWT_SECRET=change-this-secret-in-production-min-32-chars

# API Keys — ohne Key wird der jeweilige Adapter via @ConditionalOnProperty deaktiviert
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_API_KEY=
GITHUB_TOKEN=
NEWSAPI_KEY=
